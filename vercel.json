{
    "redirects": [
        {
            "source": "/movie/:path*",
            "destination": "https://dert-movie.vercel.app/:path*",
            "permanent": true
        },
        {
            "source": "/ai/:path*",
            "destination": "https://dert-ai.vercel.app/:path*",
            "permanent": true
        },
        {
            "source": "/rdd/:path*",
            "destination": "https://rdd-dert.vercel.app/:path*",
            "permanent": true
        },
        {
            "source": "/omniencoder/:path*",
            "destination": "https://omniencoder.vercel.app/:path*",
            "permanent": true
        },
        {
            "source": "/fdert/:path*",
            "destination": "https://fdert.vercel.app/:path*",
            "permanent": true
        },
        {
            "source": "/message/:path*",
            "destination": "https://messagesfun.vercel.app/:path*",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://files.dertjustwhy.ca/api/$1"
        },
        {
            "source": "/files/(.*)",
            "destination": "https://files.dertjustwhy.ca/files/$1"
        },
        {
            "source": "/download/:name",
            "destination": "https://files.dertjustwhy.ca/files/:name"
        },
        {
            "source": "/file/:name",
            "destination": "/api/view?name=:name"
        }
    ]
}